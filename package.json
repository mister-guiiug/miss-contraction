{
  "name": "miss-contraction",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "cross-env ANALYZE=1 npm run build",
    "build:netlify": "tsc -b && REACT_PREVIEW=1 vite build",
    "build:react-preview": "tsc -b && REACT_PREVIEW=1 vite build",
    "preview": "vite preview --base /miss-contraction/",
    "preview:react": "REACT_PREVIEW=1 vite preview --base /miss-contraction-react/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:storage": "playwright test --grep @storage",
    "test:e2e:perf": "playwright test --grep @performance",
    "test:e2e:errors": "playwright test --grep @errors",
    "test:e2e:journey": "playwright test --grep @journey",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:e2e:load": "playwright test --grep @load",
    "test:e2e:mobile": "playwright test --grep @mobile --project=mobile-chrome --project=mobile-safari",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:snapshots:update": "vitest run --reporter=verbose --update",
    "test:all": "npm run test && npm run test:e2e",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "type-check": "tsc --noEmit",
    "sync:vscode:tasks": "node scripts/sync-vscode-tasks.mjs",
    "check:vscode:tasks": "node scripts/sync-vscode-tasks.mjs --check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@eslint/js": "^9.39.4",
    "@mister-guiiug/dev-wpa-config": "^1.2.0",
    "@playwright/test": "^1.49.1",
    "@sentry/vite-plugin": "^2.22.6",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "axe-core": "^4.8.0",
    "cross-env": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4",
    "web-vitals": "^4.2.0"
  },
  "dependencies": {
    "@sentry/react": "^8.45.0",
    "i18next": "^26.0.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  }
}
