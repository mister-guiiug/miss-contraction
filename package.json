{
  "name": "miss-contraction",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --base /miss-contraction/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
