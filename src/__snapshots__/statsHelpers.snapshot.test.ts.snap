// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Snapshot: computeThresholdBadge - settings variés > durée minimale 60s (contractions de 60s OK) (snapshot) 1`] = `"match"`;

exports[`Snapshot: computeThresholdBadge - settings variés > durée minimale 90s (contractions de 60s insuffisantes) (snapshot) 1`] = `"approaching"`;

exports[`Snapshot: computeThresholdBadge - settings variés > règle 4-1-1 (intervalleMax=4min) (snapshot) 1`] = `"calm"`;

exports[`Snapshot: computeThresholdBadge - settings variés > règle 5-1-1 avec 4 contractions consécutives requises (snapshot) 1`] = `"match"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état "approaching" : rythme qui se resserre (snapshot) 1`] = `"approaching"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état "calm" : contractions courtes, durée insuffisante (snapshot) 1`] = `"approaching"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état "calm" : contractions espacées (snapshot) 1`] = `"calm"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état "empty" : aucun enregistrement (snapshot) 1`] = `"empty"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état "match" : règle 5-1-1 atteinte (snapshot) 1`] = `"match"`;

exports[`Snapshot: computeThresholdBadge - tous les états > état pour une seule contraction (snapshot) 1`] = `"calm"`;

